# PushMyCV — Environment Variables
# Copy to .env and fill in values
# For Coolify: set these in the UI → Application → Environment Variables

# ============================================
# Supabase — Jobeazy DB (user data, resumes)
# ============================================
SUPABASE_URL=https://zhjzrlmssxhhmmjymilz.supabase.co
SUPABASE_KEY=your-anon-key

# ============================================
# Supabase — Fastify DB (queue, results)
# ============================================
FASTIFY_SUPABASE_URL=https://your-fastify-project.supabase.co
FASTIFY_SUPABASE_KEY=your-fastify-anon-key

# ============================================
# Authentication
# ============================================
JWT_SECRET=your-jwt-secret-min-32-chars
API_KEY=your-api-key

# ============================================
# LLM Providers
# ============================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-key  # optional

# ============================================
# Frontend-specific (set in Coolify UI as NEXT_PUBLIC_* env vars)
# ============================================
NEXT_PUBLIC_FASTIFY_API_URL=https://api.pushmycv.com
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_KEY}

# ============================================
# Optional: Redis (uncomment if using)
# ============================================
# REDIS_PASSWORD=your-redis-password

# ============================================
# Optional: Coolify Deploy (GitHub Actions)
# ============================================
# COOLIFY_API_URL=https://coolify.yourdomain.com/api/v1
# COOLIFY_API_TOKEN=your-coolify-api-token
# COOLIFY_APP_ID=your-app-id
# COOLIFY_DEPLOY_WEBHOOK_URL=https://coolify.yourdomain.com/api/v1/deploy/...
